<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:steam.ViewModels"
        xmlns:models="clr-namespace:steam.Models"
        xmlns:converters="clr-namespace:Avalonia.Data.Converters;assembly=Avalonia.Base"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="steam.MainWindow"
        x:Name="Root"
        x:DataType="vm:MainViewModel"
        Title="Launcher"
        Width="1100" Height="700">
	<Window.Resources>
		<LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
			<GradientStop Offset="0" Color="#1C2636"/>
			<GradientStop Offset="0.5" Color="#121722"/>
			<GradientStop Offset="1" Color="#090D14"/>
		</LinearGradientBrush>
		<LinearGradientBrush x:Key="CardBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
			<GradientStop Offset="0" Color="#202939"/>
			<GradientStop Offset="0.55" Color="#182232"/>
			<GradientStop Offset="1" Color="#121A28"/>
		</LinearGradientBrush>
		<LinearGradientBrush x:Key="CoverBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
			<GradientStop Offset="0" Color="#1A2331"/>
			<GradientStop Offset="0.55" Color="#131C2A"/>
			<GradientStop Offset="1" Color="#0E1520"/>
		</LinearGradientBrush>
		<SolidColorBrush x:Key="CardHoverBrush" Color="#263246"/>
		<SolidColorBrush x:Key="SubtleTextBrush" Color="#A7B1C4"/>
		<SolidColorBrush x:Key="AccentBrush" Color="#7EB6FF"/>
		<SolidColorBrush x:Key="PanelBrush" Color="#8018202D"/>
	</Window.Resources>

	<Window.Styles>
		<Style Selector="TextBlock">
			<Setter Property="Foreground" Value="#F2F6FF"/>
		</Style>
		<Style Selector="TextBlock.h1">
			<Setter Property="FontSize" Value="26"/>
			<Setter Property="FontWeight" Value="Bold"/>
		</Style>
		<Style Selector="TextBlock.subtle">
			<Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}"/>
		</Style>
		<Style Selector="Grid.appRoot">
			<Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
		</Style>
		<Style Selector="Border.headerPanel">
			<Setter Property="Background" Value="{StaticResource PanelBrush}"/>
			<Setter Property="BorderBrush" Value="#233044"/>
		</Style>
		<Style Selector="Border.card">
			<Setter Property="CornerRadius" Value="15"/>
			<Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
			<Setter Property="BorderBrush" Value="#2F3B4F"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>
		<Style Selector="Border.cover">
			<Setter Property="Background" Value="{StaticResource CoverBackgroundBrush}"/>
		</Style>
		<Style Selector="Button.cardButton">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="HorizontalAlignment" Value="Stretch"/>
			<Setter Property="VerticalAlignment" Value="Stretch"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="RenderTransform" Value="scale(1)"/>
			<Setter Property="RenderTransformOrigin" Value="50%,50%"/>
			<Setter Property="Transitions">
				<Transitions>
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.14"/>
				</Transitions>
			</Setter>
			<Setter Property="Template">
				<ControlTemplate>
					<ContentPresenter Content="{TemplateBinding Content}"
					                  ContentTemplate="{TemplateBinding ContentTemplate}"
					                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
					                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
					                  Padding="{TemplateBinding Padding}"/>
				</ControlTemplate>
			</Setter>
		</Style>
		<Style Selector="Button.cardButton:pointerover">
			<Setter Property="RenderTransform" Value="scale(1.025)"/>
		</Style>
		<Style Selector="Button.cardButton:pointerover /template/ Border#border">
			<Setter Property="Background" Value="Transparent"/>
		</Style>
		<Style Selector="Button.cardButton:pressed /template/ Border#border">
			<Setter Property="Background" Value="Transparent"/>
		</Style>
		<Style Selector="Button.cardButton:focus /template/ Border#border">
			<Setter Property="Background" Value="Transparent"/>
		</Style>
		<Style Selector="Button.actionButton">
			<Setter Property="Background" Value="#243145"/>
			<Setter Property="BorderBrush" Value="#3C4A61"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Foreground" Value="#F2F6FF"/>
			<Setter Property="Padding" Value="14,8"/>
		</Style>
		<Style Selector="Button.actionButton:pointerover /template/ Border#border">
			<Setter Property="Background" Value="#2E3D55"/>
		</Style>
		<Style Selector="Button.themeButton">
			<Setter Property="Background" Value="#1B283A"/>
			<Setter Property="BorderBrush" Value="#3C4A61"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Foreground" Value="#F2F6FF"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Padding" Value="14,8"/>
			<Setter Property="MinWidth" Value="96"/>
		</Style>
		<Style Selector="Button.themeButton:pointerover /template/ Border#border">
			<Setter Property="Background" Value="#26364C"/>
		</Style>
		<Style Selector="ComboBox, TextBox">
			<Setter Property="Background" Value="#17202D"/>
			<Setter Property="BorderBrush" Value="#35445A"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Foreground" Value="#F2F6FF"/>
			<Setter Property="Padding" Value="12,8"/>
		</Style>
		<Style Selector="Grid.appRoot.day">
			<Setter Property="Background" Value="#F3F6F1"/>
		</Style>
		<Style Selector="Grid.day TextBlock">
			<Setter Property="Foreground" Value="#223047"/>
		</Style>
		<Style Selector="Grid.day TextBlock.subtle">
			<Setter Property="Foreground" Value="#6C7890"/>
		</Style>
		<Style Selector="Grid.day Border.headerPanel">
			<Setter Property="Background" Value="#F9FBF7"/>
			<Setter Property="BorderBrush" Value="#D8E1D8"/>
		</Style>
		<Style Selector="Grid.day Border.card">
			<Setter Property="Background" Value="#FCFDF9"/>
			<Setter Property="BorderBrush" Value="#D7E0D6"/>
		</Style>
		<Style Selector="Grid.day Border.cover">
			<Setter Property="Background" Value="#E9F0EA"/>
		</Style>
		<Style Selector="Grid.day Button.actionButton">
			<Setter Property="Background" Value="#E5ECDF"/>
			<Setter Property="BorderBrush" Value="#CBD8C8"/>
			<Setter Property="Foreground" Value="#223047"/>
		</Style>
		<Style Selector="Grid.day Button.actionButton:pointerover /template/ Border#border">
			<Setter Property="Background" Value="#DCE7D7"/>
		</Style>
		<Style Selector="Grid.day Button.actionButton:pointerover">
			<Setter Property="Foreground" Value="#223047"/>
		</Style>
		<Style Selector="Grid.day Button.themeButton">
			<Setter Property="Background" Value="#FFFFFF"/>
			<Setter Property="BorderBrush" Value="#CBD8C8"/>
			<Setter Property="Foreground" Value="#223047"/>
		</Style>
		<Style Selector="Grid.day Button.themeButton:pointerover /template/ Border#border">
			<Setter Property="Background" Value="#EEF4EA"/>
		</Style>
		<Style Selector="Grid.day Button.themeButton:pointerover">
			<Setter Property="Foreground" Value="#223047"/>
		</Style>
		<Style Selector="Grid.day ComboBox, Grid.day TextBox">
			<Setter Property="Background" Value="#FFFFFF"/>
			<Setter Property="BorderBrush" Value="#CBD8C8"/>
			<Setter Property="Foreground" Value="#223047"/>
		</Style>
	</Window.Styles>

	<Grid Classes="appRoot" RowDefinitions="Auto,Auto,*" ColumnDefinitions="*"
	      Classes.day="{Binding IsDayMode}">
		<Border Classes="headerPanel" Padding="20,18" BorderThickness="0,0,0,1">
			<Grid ColumnDefinitions="Auto,*,Auto">
				<StackPanel Spacing="2" VerticalAlignment="Center">
					<TextBlock Classes="h1" Text="软件启动器"/>
					<TextBlock Classes="subtle" Text="快速整理和打开你的游戏、桌面应用与网页" FontSize="13"/>
				</StackPanel>
				<StackPanel Orientation="Horizontal" Spacing="10" Grid.Column="2" VerticalAlignment="Center">
					<ComboBox ItemsSource="{Binding Categories}"
					          SelectedItem="{Binding SelectedCategory}"
					          MinWidth="112"
					          VerticalAlignment="Center"/>
					<TextBox Width="280"
					         Watermark="搜索..."
					         VerticalAlignment="Center"
					         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
					<Button Classes="themeButton"
					        Content="{Binding ThemeToggleText}"
					        Command="{Binding ToggleThemeCommand}"
					        VerticalAlignment="Center"/>
					<Button Classes="actionButton" Content="刷新" Command="{Binding RefreshCommand}" MinWidth="84"/>
				</StackPanel>
			</Grid>
		</Border>
		
		<ScrollViewer Grid.Row="2" Margin="10" Padding="8,2,8,64">
			<ItemsControl ItemsSource="{Binding FilteredGames}" Width="1030" HorizontalAlignment="Center">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel Orientation="Horizontal" ItemWidth="206" ItemHeight="238"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>

				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="models:GameEntry">
						<Button Command="{Binding DataContext.OpenCommand, ElementName=Root}"
						        CommandParameter="{Binding}"
						        Classes="cardButton"
						        Margin="9"
						        HorizontalContentAlignment="Stretch"
						        VerticalContentAlignment="Stretch">
							<Border Classes="card" Padding="11">
								<Grid RowDefinitions="*,Auto" ColumnDefinitions="*">
									<Grid ClipToBounds="True">
										<Border Classes="cover" CornerRadius="12"/>
										<Image Source="{Binding CoverImage}"
										       Stretch="Uniform"
										       HorizontalAlignment="Center"
										       VerticalAlignment="Center"
										       MaxWidth="174"
										       MaxHeight="162"/>
										<TextBlock Text="{Binding IconEmoji}" FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center"
										           Foreground="{StaticResource AccentBrush}" IsVisible="{Binding CoverImage, Converter={x:Static converters:ObjectConverters.IsNull}}"/>
									</Grid>
									<StackPanel Grid.Row="1" Margin="4,12,4,0" Spacing="4">
										<TextBlock Text="{Binding Name}" HorizontalAlignment="Center" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
										<TextBlock Classes="subtle" Text="{Binding Category}" HorizontalAlignment="Center" FontSize="12"/>
									</StackPanel>
								</Grid>
							</Border>
						</Button>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</Grid>
</Window>
