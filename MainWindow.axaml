<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:steam.ViewModels"
        xmlns:models="clr-namespace:steam.Models"
        xmlns:converters="clr-namespace:Avalonia.Data.Converters;assembly=Avalonia.Base"
        mc:Ignorable="d" d:DesignWidth="1180" d:DesignHeight="760"
        x:Class="steam.MainWindow"
        x:Name="Root"
        x:DataType="vm:MainViewModel"
        Title="Nebula Library"
        Width="1180" Height="760"
        MinWidth="960" MinHeight="640">
	<Window.Resources>
		<LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
			<GradientStop Offset="0" Color="#142238"/>
			<GradientStop Offset="0.35" Color="#101722"/>
			<GradientStop Offset="1" Color="#070A10"/>
		</LinearGradientBrush>
		<LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
			<GradientStop Offset="0" Color="#2E6F95"/>
			<GradientStop Offset="0.45" Color="#1E3F5A"/>
			<GradientStop Offset="1" Color="#1A182A"/>
		</LinearGradientBrush>
		<LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,0">
			<GradientStop Offset="0" Color="#71E6C3"/>
			<GradientStop Offset="1" Color="#77A7FF"/>
		</LinearGradientBrush>
		<LinearGradientBrush x:Key="CardSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
			<GradientStop Offset="0" Color="#253247"/>
			<GradientStop Offset="1" Color="#151C2A"/>
		</LinearGradientBrush>
		<SolidColorBrush x:Key="PanelBrush" Color="#B0121A26"/>
		<SolidColorBrush x:Key="PanelBorderBrush" Color="#31435C"/>
		<SolidColorBrush x:Key="TextBrush" Color="#F4F8FF"/>
		<SolidColorBrush x:Key="SubtleTextBrush" Color="#A9B6C9"/>
		<SolidColorBrush x:Key="MutedTextBrush" Color="#76839A"/>
	</Window.Resources>

	<Window.Background>
		<StaticResource ResourceKey="AppBackgroundBrush"/>
	</Window.Background>

	<Window.Styles>
		<Style Selector="TextBlock">
			<Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
		</Style>
		<Style Selector="TextBlock.kicker">
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Foreground" Value="#81E3CA"/>
			<Setter Property="LetterSpacing" Value="1.2"/>
		</Style>
		<Style Selector="TextBlock.heroTitle">
			<Setter Property="FontSize" Value="34"/>
			<Setter Property="FontWeight" Value="Black"/>
			<Setter Property="LineHeight" Value="40"/>
		</Style>
		<Style Selector="TextBlock.sectionTitle">
			<Setter Property="FontSize" Value="20"/>
			<Setter Property="FontWeight" Value="Bold"/>
		</Style>
		<Style Selector="TextBlock.subtle">
			<Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}"/>
		</Style>
		<Style Selector="TextBlock.muted">
			<Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
		</Style>
		<Style Selector="Border.glassPanel">
			<Setter Property="Background" Value="{StaticResource PanelBrush}"/>
			<Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="28"/>
		</Style>
		<Style Selector="Border.statCard">
			<Setter Property="Background" Value="#1B2738"/>
			<Setter Property="BorderBrush" Value="#344862"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="18"/>
			<Setter Property="Padding" Value="16"/>
		</Style>
		<Style Selector="Border.gameCard">
			<Setter Property="CornerRadius" Value="22"/>
			<Setter Property="Background" Value="{StaticResource CardSurfaceBrush}"/>
			<Setter Property="BorderBrush" Value="#30425B"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BoxShadow" Value="0 16 34 0 #55000000"/>
		</Style>
		<Style Selector="Button.cardButton">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="HorizontalAlignment" Value="Stretch"/>
			<Setter Property="VerticalAlignment" Value="Stretch"/>
			<Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
		</Style>
		<Style Selector="Button.cardButton:pointerover /template/ Border#border">
			<Setter Property="Background" Value="#16283D"/>
		</Style>
		<Style Selector="Button.primaryAction">
			<Setter Property="Background" Value="{StaticResource AccentBrush}"/>
			<Setter Property="Foreground" Value="#071018"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="CornerRadius" Value="16"/>
			<Setter Property="Padding" Value="18,11"/>
			<Setter Property="BorderThickness" Value="0"/>
		</Style>
		<Style Selector="Button.categoryButton">
			<Setter Property="HorizontalContentAlignment" Value="Stretch"/>
			<Setter Property="Background" Value="#101A28"/>
			<Setter Property="BorderBrush" Value="#28384D"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="16"/>
			<Setter Property="Padding" Value="14,12"/>
		</Style>
		<Style Selector="ComboBox, TextBox">
			<Setter Property="Background" Value="#111C2A"/>
			<Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
			<Setter Property="BorderBrush" Value="#334862"/>
			<Setter Property="CornerRadius" Value="16"/>
			<Setter Property="Padding" Value="14,10"/>
		</Style>
	</Window.Styles>

	<Grid ClipToBounds="True">
		<Ellipse Width="520" Height="520" Fill="#203F6E" Opacity="0.22" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-190,-180,0,0"/>
		<Ellipse Width="420" Height="420" Fill="#2A806C" Opacity="0.16" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-150,-120"/>
		<Ellipse Width="260" Height="260" Fill="#8C6A36" Opacity="0.12" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,90,120,0"/>

		<Grid Margin="28" ColumnDefinitions="292,*" RowDefinitions="Auto,*" ColumnSpacing="24" RowSpacing="24">
			<Border Grid.ColumnSpan="2" Classes="glassPanel" Padding="28">
				<Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
					<StackPanel Spacing="8">
						<TextBlock Classes="kicker" Text="NEBULA LAUNCHER"/>
						<TextBlock Classes="heroTitle" Text="把你的游戏、应用和网页入口收进一个发光的甲板。" MaxWidth="670" TextWrapping="Wrap"/>
						<TextBlock Classes="subtle" Text="选择分类、快速搜索，然后一键启动。今晚的库房已经点灯。" FontSize="15"/>
					</StackPanel>
					<Border Grid.Column="1" Background="{StaticResource HeroBrush}" CornerRadius="24" Padding="22" MinWidth="230" BoxShadow="0 18 44 0 #66000000">
						<Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
							<TextBlock Text="库状态" Classes="muted"/>
							<TextBlock Grid.Row="1" Text="{Binding SearchStatusText}" FontSize="24" FontWeight="Black"/>
							<TextBlock Grid.Row="2" Text="{Binding LibraryPath}" Classes="subtle" TextTrimming="CharacterEllipsis" MaxWidth="250"/>
						</Grid>
					</Border>
				</Grid>
			</Border>

			<StackPanel Grid.Row="1" Spacing="18">
				<Border Classes="glassPanel" Padding="20">
					<StackPanel Spacing="18">
						<TextBlock Classes="sectionTitle" Text="控制台"/>
						<TextBlock Classes="subtle" Text="当前筛选"/>
						<Border Background="#102337" BorderBrush="#2B5269" BorderThickness="1" CornerRadius="18" Padding="16">
							<StackPanel Spacing="4">
								<TextBlock Text="{Binding ActiveFilterLabel}" FontSize="22" FontWeight="Black"/>
								<TextBlock Text="{Binding SearchStatusText}" Classes="subtle"/>
							</StackPanel>
						</Border>
						<ComboBox ItemsSource="{Binding Categories}"
						          SelectedItem="{Binding SelectedCategory}"
						          HorizontalAlignment="Stretch"/>
						<TextBox Watermark="搜索名称或路径..."
						         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
						<Button Classes="primaryAction" Content="刷新库" Command="{Binding RefreshCommand}" HorizontalAlignment="Stretch"/>
					</StackPanel>
				</Border>

				<Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
					<Border Classes="statCard">
						<StackPanel>
							<TextBlock Text="全部" Classes="muted"/>
							<TextBlock Text="{Binding TotalGames}" FontSize="28" FontWeight="Black"/>
						</StackPanel>
					</Border>
					<Border Grid.Column="1" Classes="statCard">
						<StackPanel>
							<TextBlock Text="游戏" Classes="muted"/>
							<TextBlock Text="{Binding GameCount}" FontSize="28" FontWeight="Black"/>
						</StackPanel>
					</Border>
					<Border Grid.Row="1" Classes="statCard">
						<StackPanel>
							<TextBlock Text="桌面" Classes="muted"/>
							<TextBlock Text="{Binding DesktopCount}" FontSize="28" FontWeight="Black"/>
						</StackPanel>
					</Border>
					<Border Grid.Row="1" Grid.Column="1" Classes="statCard">
						<StackPanel>
							<TextBlock Text="网页" Classes="muted"/>
							<TextBlock Text="{Binding WebCount}" FontSize="28" FontWeight="Black"/>
						</StackPanel>
					</Border>
				</Grid>
			</StackPanel>

			<Border Grid.Row="1" Grid.Column="1" Classes="glassPanel" Padding="22">
				<Grid RowDefinitions="Auto,*" RowSpacing="18">
					<Grid ColumnDefinitions="*,Auto">
						<StackPanel Spacing="4">
							<TextBlock Classes="sectionTitle" Text="启动甲板"/>
							<TextBlock Classes="subtle" Text="点击卡片即可打开；没有封面的项目会使用分类徽记。"/>
						</StackPanel>
						<Border Grid.Column="1" Background="#132033" BorderBrush="#2E4058" BorderThickness="1" CornerRadius="999" Padding="14,8" VerticalAlignment="Center">
							<TextBlock Text="{Binding SearchStatusText}" Classes="subtle"/>
						</Border>
					</Grid>

					<ScrollViewer Grid.Row="1" Padding="2,0,8,4">
						<ItemsControl ItemsSource="{Binding FilteredGames}">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<WrapPanel Orientation="Horizontal" ItemWidth="214" ItemHeight="264"/>
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>

							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="models:GameEntry">
									<Button Command="{Binding DataContext.OpenCommand, ElementName=Root}"
									        CommandParameter="{Binding}"
									        Classes="cardButton"
									        ToolTip.Tip="{Binding DisplayPath}"
									        Margin="10"
									        HorizontalContentAlignment="Stretch"
									        VerticalContentAlignment="Stretch">
										<Border Classes="gameCard" Padding="12">
											<Grid RowDefinitions="*,Auto" ColumnDefinitions="*">
												<Grid ClipToBounds="True">
													<Border Background="#101826" CornerRadius="18"/>
													<Ellipse Width="118" Height="118" Fill="#244E67" Opacity="0.42" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-36,-28,0,0"/>
													<Ellipse Width="96" Height="96" Fill="#58D2B5" Opacity="0.16" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-28,-20"/>
													<Image Source="{Binding CoverImage}"
													       Stretch="UniformToFill"
													       HorizontalAlignment="Center"
													       VerticalAlignment="Center"
													       Width="190"
													       Height="176"/>
													<TextBlock Text="{Binding IconEmoji}" FontSize="58" HorizontalAlignment="Center" VerticalAlignment="Center"
													           Foreground="#83E8CE" IsVisible="{Binding CoverImage, Converter={x:Static converters:ObjectConverters.IsNull}}"/>
													<Border Background="#CC071018" CornerRadius="999" Padding="10,5" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10">
														<TextBlock Text="{Binding Category}" FontSize="11" FontWeight="Bold" Foreground="#BFEFE4"/>
													</Border>
												</Grid>
												<StackPanel Grid.Row="1" Margin="2,12,2,0" Spacing="6">
													<TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" TextTrimming="CharacterEllipsis"/>
													<TextBlock Text="{Binding DisplayPath}" Classes="muted" FontSize="11" TextTrimming="CharacterEllipsis"/>
												</StackPanel>
											</Grid>
										</Border>
									</Button>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</ScrollViewer>
				</Grid>
			</Border>
		</Grid>
	</Grid>
</Window>
